# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# ── Mistral AI ────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=your_mistral_api_key_here

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Get this from: Cloudflare Zero Trust → Networks → Tunnels → your tunnel → Configure
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here

# ── ElevenLabs (Marimba's voice) ─────────────────────────────────────────────
# Without these, Marimba responds with text only — no audio.
# ELEVENLABS_VOICE_ID: create a voice at elevenlabs.io and paste the ID here.
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# ── Optional ──────────────────────────────────────────────────────────────────
ENVIRONMENT=production
